{
  "editable": true,
  "panels": [
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 2,
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["count", "sum"]
        }
      },
      "targets": [
        {
          "expr": "sum by (rule, priority) (rate(falcosecurity_falcosidekick_falco_events_total[5m]))",
          "legendFormat": "{{rule}} [{{priority}}]",
          "refId": "A"
        }
      ],
      "title": "Falco Events Rate (Last 5m)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 4,
      "options": {
        "showHeader": true,
        "footer": {
          "show": false,
          "reducer": ["sum"]
        }
      },
      "targets": [
        {
          "expr": "falcosecurity_falcosidekick_falco_events_total",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total Event Counts by Rule/Host",
      "type": "table",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            }
          }
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["falco", "security"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Falco Security - Modern Dashboard",
  "uid": "falco-security-modern"
}
